{
  "name": "daily-quiz",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "secrets:local": "echo \"ANTHROPIC_API_KEY=$(doppler secrets get ANTHROPIC_API_KEY --plain)\" > .dev.vars",
    "secrets:push": "doppler secrets get ANTHROPIC_API_KEY --plain | wrangler secret put ANTHROPIC_API_KEY",
    "preview": "vite build && npm run secrets:local && wrangler dev; rm -f .dev.vars",
    "deploy": "vite build && wrangler deploy"
  },
  "dependencies": {
    "lucide-react": "^0.383.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.4",
    "vite": "^5.3.1",
    "wrangler": "^3.78.0"
  }
}
